import csv

def float foo()
	Csv f("games.csv", ',')
	array<str> col = f.get_col("gender")
	col.print()
	for c in f.get_cols()
		print(c)
	return 0

def float bar()
	File f("games.csv")
	while f.opened()
		str line = f.read()
		print("line: ", line)
		var v = line.split(',')
		if (v.size()!=39)
			_quit_()
	return 0

main
	foo()
	#bar()

	str i = "um-dois-tres-quatro"
	var v = i.split('-')
	v.print()

