class cfg
	int bs, num_workers
	ctor()
		self.bs = 4
		self.num_workers = 3


class Dataset
    int batch_size, yield_ptr, _len, num_workers, epoch
    array<str> files
	channel<int, 3> load_ch
	tensor_cpu x, y

    ctor(i batch_size, i num_workers, str path)
        self.batch_size = batch_size
        self.num_workers = num_workers
            
        self.files = glob(path)

        self.yield_ptr = 0
		self.epoch=0

        self._len = self.files.size()
        self.shuf()

		self.x = new tensor_cpu([num_workers, batch_size], [28,28])
		self.y = new tensor_cpu([num_workers, batch_size], [1])

    def int shuf()
		self.files.shuffle()
		0

    def float terminate_workers()
        print("Terminating workers")
        self.load_ch.terminate()

    def int increment_yield_ptr()
		lock "yield"
			if (self.yield_ptr + self.batch_size*(self.num_workers+2)) <= self._len
				int ret = self.yield_ptr
				self.yield_ptr = self.yield_ptr + self.batch_size
			else
				self.yield_ptr = 0
				self.shuf()
				self.epoch=self.epoch+1
        return self.yield_ptr

    def float getitem_w(i idx, i b)
		lock "yield"
			var aux = self.files[idx]

		var img = self.x.at(b)
		img.load_img(aux)

		var y = self.y.at(b)
		y[0] = aux.split('/')[-2].float()

    def float worker()
        print("Start worker")

        int yield_ptr, bs=self.batch_size
		print("worker ", tid)

        while self.load_ch.alive()
			yield_ptr = self.increment_yield_ptr()
			#print("yield ", yield_ptr, " / ", self.epoch, " from ", w)

			for b=0, b<bs
				self.getitem_w(yield_ptr+b, b)
				
			self.load_ch <- tid
			self.x.switch()
			self.y.switch()

    def tuple<tensor,tensor> attr_w()

		int w <- self.load_ch

		var x = self.x.load(w)
		var y = self.y.load(w)
		x = x.view([$cfg.bs, -1])

        return x, y


class Linear
	tensor w
	ctor(int m, int n, str init)
		self.w = new tensor([n,m], init)
		self.w.as_weight()
	def tensor forward(t x)
		return x@self.w

class MyModel
	Linear l1, l2
	ctor()
		self.l1 = new Linear(784, 768, "xavu")
		self.l2 = new Linear(768, 10, "xavu")
	
	def tensor forward(tensor x)
		x = self.l1.forward(x)
		x = relu(x)
		x = self.l2.forward(x)
		return x



main
	#join_gc()
	#foo()
	#bar()
	#_quit_()

	Dataset ds($cfg.bs, 3, "/nsd_home/Datasets/mnist/train/*/*.jpg")
	MyModel model()

	AdamW optim(0.001, 0.9, 0.98)
	#SGD optim(0.1)

	finish
		asyncs 3 ds.worker()
		for i=0, i<1000
			tensor a, b
			a, b = ds.attr_w()
			var y_hat = model.forward(a)
			ce_loss(y_hat, b)

			$backprop.backward()
			optim.step()
		ds.terminate_workers()

	print("done")

	#tensor t = image_tensor("/nsd_home/Datasets/mnist/test/1/1004.jpg").view([1,784])
	tensor t = image_tensor("/nsd_home/Datasets/mnist/test/2/1407.jpg").view([1,784])
	#tensor t = image_tensor("/nsd_home/Datasets/mnist/test/9/322.jpg").view([1,784])

	print("OUT IS")
